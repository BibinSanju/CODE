generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(uuid())
  githubId  String   @unique
  username  String
  createdAt DateTime @default(now())
}

model Question {
  id          String   @id @default(uuid())
  category    String   // DSA, DB, ML, SysDesign
  title       String
  description String
  testCases   Json?    // Piston execution payloads
}