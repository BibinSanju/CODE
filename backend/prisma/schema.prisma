generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}


model User {
  id          String       @id @default(uuid())
  githubId    String?      @unique  // Made optional for native auth
  email       String?      @unique  // Added for native auth
  password    String?      // Added for native auth
  username    String
  createdAt   DateTime     @default(now())
  
  // Profile Stats
  rank        Int          @default(1000000)
  reputation  Int          @default(0)
  views       Int          @default(0)
  discuss     Int          @default(0)
  solution    Int          @default(0)
  contestRating Int        @default(1400)
  globalRanking Int        @default(100000)
  attendedContests Int     @default(0)

  submissions Submission[] // Relation to track solved problems
}

model Question {
  id          String       @id @default(uuid())
  category    String       // DSA, DB, ML, SysDesign
  subtopic    String       @default("General") // e.g., DP, BFS, DFS
  difficulty  String       @default("Medium") // Easy, Medium, Hard
  title       String
  description String
  testCases   Json?    
  submissions Submission[] // Relation to track who solved it
}

model Submission {
  id          String   @id @default(uuid())
  userId      String
  questionId  String
  status      String   // e.g., "Pass", "Fail"
  code        String
  language    String
  submittedAt DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id])
  question    Question @relation(fields: [questionId], references: [id])
}